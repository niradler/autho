{
  "name": "autho",
  "version": "0.2.0",
  "private": true,
  "type": "module",
  "packageManager": "bun@1.3.10",
  "engines": {
    "bun": ">=1.3.10"
  },
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "autho": "bun run ./apps/cli/src/index.ts",
    "daemon": "bun run ./apps/daemon/src/index.ts serve",
    "web": "bun run ./apps/web/src/index.ts serve",
    "build:cli": "bun build ./apps/cli/src/index.ts --outfile ./apps/cli/dist/autho.js --target bun",
    "build:daemon": "bun build ./apps/daemon/src/index.ts --outfile ./dist/autho-daemon.js --target bun",
    "build:web": "bun build ./apps/web/src/index.ts --outfile ./dist/autho-web.js --target bun",
    "build:cli:compile": "bun build ./apps/cli/src/index.ts --outfile ./apps/cli/dist/autho --target bun --compile",
    "build:daemon:compile": "bun build ./apps/daemon/src/index.ts --outfile ./dist/autho-daemon --target bun --compile",
    "build:web:compile": "bun build ./apps/web/src/index.ts --outfile ./dist/autho-web --target bun --compile",
    "build": "bun run build:cli && bun run build:daemon && bun run build:web",
    "build:compile": "bun run build:cli:compile && bun run build:daemon:compile && bun run build:web:compile",
    "test": "bun test",
    "test:v2": "bun test",
    "format": "bun run ./scripts/quality.ts format:check",
    "format:write": "bun run ./scripts/quality.ts format:write",
    "lint": "bun run ./scripts/quality.ts lint",
    "typecheck": "bun run ./scripts/quality.ts typecheck",
    "check": "bun run lint && bun run format && bun run typecheck && bun run test",
    "hooks:install": "bun run ./scripts/install-hooks.ts"
  },
  "keywords": [
    "secrets",
    "otp",
    "bun",
    "agent-secrets"
  ],
  "author": "Nir Adler",
  "license": "MIT",
  "description": "Local-first secret manager for humans and coding agents, rebuilt on Bun"
}
